name /example/hello/controller/NDNSF/ControllerPolicy/v1

provider-policies
{
    provider-policy
    {
        for /example/hello/provider
        allow
        {
            /HELLO
        }
    }
    provider-policy
    {
        for /example/hello/provider/unauthorized
        allow
        {
            /OTHER
        }
    }
}

user-policies
{
    user-policy
    {
        for /example/hello/user
        allow
        {
            /HELLO
        }
    }
}
