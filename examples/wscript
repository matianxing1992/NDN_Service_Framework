                linkflags=['-Wl,-rpath,$ORIGIN/..'],
                install_path=None)

    if not bld.env.WITH_EXAMPLES:
        return

    bld.program(name='generic-dynamic-user-provider',
                target='generic-dynamic-user-provider',
                source=(["generic-dynamic-user-provider.cpp"] +
                        bld.path.parent.ant_glob([
                            'ndn-service-framework/NDNSFMessages.cpp',
                            'ndn-service-framework/BloomFilter.cpp',
                            'ndn-service-framework/ConfigManager.cpp',
                            'ndn-service-framework/Service.cpp',
                            'ndn-service-framework/ServiceProvider.cpp',
                            'ndn-service-framework/ServiceUser.cpp',
                            'ndn-service-framework/HybridMessageCrypto.cpp',
                            'ndn-service-framework/TimelineTrace.cpp',
                            'ndn-service-framework/common.cpp',
                            'ndn-service-framework/utils.cpp',
                        ])),
                includes= ['..','../ndn-service-framework'],
                use='NDN_CXX NDN_SVS PROTOBUF NAC-ABE NDNSD OPENSSL',
                cxxflags=['-fPIC'],
                install_path=None)

    bld.install_files('/usr/local/bin', ['trust-schema.conf', 'trust-any.conf', 'example_muas.policies'])
